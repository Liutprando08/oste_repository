<?xml version="1.0" encoding="UTF-8"?>
<addon id="plugin.video.onepace" name="One Pace" version="1.0.0" provider-name="One Pace">
    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
    </requires>
    <extension point="xbmc.python.pluginsource" library="main.py">
        <provides>video</provides>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary lang="en">One Pace - The Definitive One Piece Viewing Experience</summary>
        <description lang="en">Watch One Pace, the fan-edited One Piece anime with filler removed, in Kodi.</description>
        <platform>all</platform>
        <language>en</language>
        <license>GPL-3.0</license>
        <assets>
          <icon>resources/onepace_logo.png</icon>
        </assets>
    </extension>
</addon>
